{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Presenta",
  "version": "0.1.0",
  "identifier": "com.techie4christ.dev.presenta",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Presenta Pro - Professional Stage Timer",
        "width": 1920,
        "height": 1080,
        "resizable": false,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Techie 4 Christ",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
